---
import "../styles/global.css";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const repoUrl = "https://github.com/nazarKuznetsov/automaticDevelopment";
const phases = ["Discovery", "Planning", "Design", "Foundation", "MVP", "Stabilization", "Production", "Growth"];
const docs = [
  ["Quickstart", "Install, configure, approve, pilot.", "quickstart"],
  ["Existing Products", "Migrate v1 without losing product history.", "existing-products"],
  ["Planning", "Stable IDs and complete Issue merge units.", "planning"],
  ["GitHub Model", "Hierarchy, dependencies, fields, states.", "github-model"],
  ["Orchestration", "Fresh tasks, worktrees, merge, handoff.", "orchestration"],
  ["Pre-PR Gate", "Independent head/base-SHA admission.", "pre-pr-gate"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Lifecycle-driven Codex development with fresh managed-worktree tasks, GitHub rolling waves, exact-SHA admission and human-authorized merges." />
    <meta name="theme-color" content="#0b0f17" />
    <title>Codex Automation Guide v2</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span><strong>Codex Automation</strong><small>Workflow schema v2</small></span>
      </a>
      <nav aria-label="Primary navigation">
        <a href={`${base}docs/quickstart/`}>Guide</a>
        <a href={repoUrl}>GitHub</a>
      </nav>
    </header>

    <main>
      <section class="hero section">
        <div class="hero-copy">
          <p class="eyebrow">Lifecycle-driven development</p>
          <h1>Plan globally. Give every accepted Issue a fresh execution context.</h1>
          <p class="lede">A GitHub-native kit for stable Issue plans, one Orchestrator per wave, one managed-worktree Worker task per leaf, independent admission, exact-SHA human authorization, and post-merge proof.</p>
          <div class="actions">
            <a class="button primary" href={`${base}docs/quickstart/`}>Start Quickstart</a>
            <a class="button secondary" href={repoUrl}>View repository</a>
          </div>
          <dl class="signals">
            <div><dt>Wave</dt><dd>≤ 5 leaf Issues</dd></div>
            <div><dt>Writers</dt><dd>≤ 2 disjoint</dd></div>
            <div><dt>Done</dt><dd>Post-merge PASS</dd></div>
          </dl>
        </div>

        <div class="tech-core-panel" aria-label="Workflow signal visualization">
          <div class="core-label"><span>Durable state</span><strong>GitHub → Codex → evidence</strong></div>
          <canvas data-tech-core id="tech-core-canvas" width="720" height="520"></canvas>
          <div class="tech-core-fallback" aria-hidden="true"><span></span></div>
        </div>
      </section>

      <section class="section lifecycle-section">
        <div class="section-heading">
          <p class="eyebrow">One lifecycle</p>
          <h2>Automation expands only after the exact contract is approved.</h2>
          <p>Humans approve the brief, wave revision, phase boundaries, high-risk choices, and exact PR/head SHA. Agents execute and reconcile ordinary approved work, then stop fail-closed when evidence changes.</p>
        </div>
        <ol class="phase-track">
          {phases.map((phase, index) => <li><span>{String(index + 1).padStart(2, "0")}</span><strong>{phase}</strong></li>)}
        </ol>
      </section>

      <section class="section split-section">
        <div class="section-heading">
          <p class="eyebrow">Quickstart</p>
          <h2>Preview first. Apply safely. Configure fail-closed.</h2>
          <p>The manifest distinguishes host-owned policy from managed kit files. A modified `AGENTS.md`, Issue Form, or workflow produces an exact merge plan and no partial write.</p>
          <a class="text-link" href={`${base}docs/quickstart/`}>Read the complete setup →</a>
        </div>
        <div class="code-card">
          <div class="code-title">Install workflow v2</div>
          <pre><code>scripts/install-kit.sh --target /path/to/repo --dry-run
scripts/install-kit.sh --target /path/to/repo --apply

# later
scripts/install-kit.sh --target /path/to/repo --upgrade</code></pre>
        </div>
      </section>

      <section class="section">
        <div class="section-heading">
          <p class="eyebrow">Canonical guide</p>
          <h2>The website renders the same Markdown installed into your repository.</h2>
        </div>
        <div class="docs-grid">
          {docs.map(([title, description, slug]) => (
            <a class="doc-card" href={`${base}docs/${slug}/`}>
              <span>{title}</span><p>{description}</p><strong>Open →</strong>
            </a>
          ))}
        </div>
      </section>

      <section class="section final-cta">
        <p class="eyebrow">Ready to adopt</p>
        <h2>Keep GitHub durable, task context fresh, and every Done state earned by post-merge evidence.</h2>
        <div class="actions"><a class="button primary" href={`${base}docs/quickstart/`}>Open the guide</a></div>
      </section>
    </main>

    <script>
      import "../scripts/copy-code.ts";
      import "../scripts/tech-core.ts";
    </script>
  </body>
</html>
