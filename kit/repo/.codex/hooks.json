{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_pr_admission.py\"",
            "timeout": 10,
            "statusMessage": "Checking pre-PR admission"
          }
        ]
      },
      {
        "matcher": "^mcp__.*create_pull_request.*$",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/pre_pr_admission.py\"",
            "timeout": 10,
            "statusMessage": "Checking pre-PR admission"
          }
        ]
      }
    ]
  }
}
