{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worker Completion Report v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "status", "issue", "pr", "branch", "commit_sha", "acceptance", "tdd", "primary_signal_status", "secondary_checks", "reviews", "admission_report", "documentation", "rollout", "findings", "human_gates"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "worker_completion" },
    "status": { "const": "PASS" },
    "issue": { "type": "integer", "minimum": 1 },
    "pr": { "type": "integer", "minimum": 1 },
    "branch": { "type": "string", "pattern": "^agent/[0-9]+-[a-z0-9][a-z0-9-]*$" },
    "commit_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "acceptance": { "type": "array", "minItems": 1 },
    "tdd": { "type": "object" },
    "primary_signal_status": { "const": "met" },
    "secondary_checks": { "type": "array", "minItems": 1 },
    "reviews": { "type": "object", "required": ["reviewer", "qa"] },
    "admission_report": { "type": "string", "minLength": 1 },
    "documentation": { "enum": ["updated", "not_needed"] },
    "rollout": { "type": "string", "minLength": 1 },
    "findings": { "type": "array" },
    "human_gates": { "type": "array", "minItems": 1 }
  },
  "additionalProperties": false
}
