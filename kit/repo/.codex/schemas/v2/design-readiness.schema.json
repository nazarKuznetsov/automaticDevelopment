{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design Readiness Packet v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "status", "flows", "screens", "components", "states", "responsive", "accessibility", "content", "assets", "evidence", "approval"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "design_readiness" },
    "status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
    "flows": { "type": "array" },
    "screens": { "type": "array" },
    "components": { "type": "array" },
    "states": { "type": "array" },
    "responsive": { "type": "array" },
    "accessibility": { "type": "array" },
    "content": { "type": "array" },
    "assets": { "type": "array" },
    "evidence": { "type": "array", "minItems": 1 },
    "approval": { "type": "object", "required": ["status"] }
  }
}
