{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-automation.local/schemas/v2/canonical-brief.schema.json",
  "title": "Canonical Brief Packet v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "product", "audience", "problem", "scenarios", "mvp", "design", "architecture", "quality_bar", "release_criteria", "risks", "assumptions", "open_decisions", "human_approval"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "canonical_brief" },
    "product": { "type": "object", "required": ["name", "one_sentence_outcome"] },
    "audience": { "type": "object", "required": ["primary"] },
    "problem": { "type": "object", "required": ["current_state", "desired_state"] },
    "scenarios": { "type": "array", "minItems": 1 },
    "mvp": { "type": "object", "required": ["in_scope", "non_goals", "acceptance"] },
    "design": { "type": "object", "required": ["references", "required_flows", "constraints"] },
    "architecture": { "type": "object", "required": ["constraints", "integrations"] },
    "quality_bar": { "type": "object" },
    "release_criteria": { "type": "array", "minItems": 1 },
    "risks": { "type": "array" },
    "assumptions": { "type": "array" },
    "open_decisions": { "type": "array" },
    "human_approval": { "type": "object", "required": ["status"] }
  },
  "additionalProperties": true
}
