{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wave Completion Report v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "wave_id", "status", "merged_outcomes", "post_merge_ci", "open_bugs", "phase_exit_implications", "worker_archives"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "wave_completion" },
    "wave_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
    "merged_outcomes": { "type": "array", "items": { "$ref": "#/$defs/merged" } },
    "post_merge_ci": { "type": "array", "items": { "$ref": "#/$defs/ci" } },
    "open_bugs": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "phase_exit_implications": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "worker_archives": { "type": "array", "items": { "$ref": "#/$defs/archive" } }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "PASS" } } },
      "then": { "properties": { "merged_outcomes": { "minItems": 1 }, "post_merge_ci": { "minItems": 1 }, "worker_archives": { "minItems": 1 } } }
    }
  ],
  "$defs": {
    "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "issue": { "type": "object", "required": ["number", "url"], "properties": { "number": { "type": "integer", "minimum": 1 }, "url": { "type": "string", "format": "uri" } }, "additionalProperties": false },
    "merged": {
      "type": "object",
      "required": ["plan_item_id", "issue", "pr", "head_sha", "merge_commit_sha", "merge_readback_url"],
      "properties": {
        "plan_item_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
        "issue": { "type": "integer", "minimum": 1 },
        "pr": { "type": "integer", "minimum": 1 },
        "head_sha": { "$ref": "#/$defs/sha" },
        "merge_commit_sha": { "$ref": "#/$defs/sha" },
        "merge_readback_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "ci": {
      "type": "object",
      "required": ["status", "commit_sha", "workflow", "run_url"],
      "properties": {
        "status": { "const": "PASS" },
        "commit_sha": { "$ref": "#/$defs/sha" },
        "workflow": { "type": "string", "minLength": 1 },
        "run_url": { "type": "string", "format": "uri", "pattern": "^https://.+/actions/runs/[0-9]+" }
      },
      "additionalProperties": false
    },
    "archive": {
      "type": "object",
      "required": ["issue", "task_id", "archived"],
      "properties": {
        "issue": { "type": "integer", "minimum": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "archived": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
