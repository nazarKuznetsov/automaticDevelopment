{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Phase Exit Report v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "phase", "status", "exit_criteria", "open_bugs", "risks", "operational_evidence", "next_phase", "human_approval"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "phase_exit" },
    "phase": { "type": "string" },
    "status": { "enum": ["PASS", "FAIL", "BLOCKED"] },
    "exit_criteria": { "type": "array", "minItems": 1 },
    "open_bugs": { "type": "array" },
    "risks": { "type": "array" },
    "operational_evidence": { "type": "array" },
    "next_phase": { "type": ["string", "null"] },
    "human_approval": { "type": "object", "required": ["status"] }
  }
}
