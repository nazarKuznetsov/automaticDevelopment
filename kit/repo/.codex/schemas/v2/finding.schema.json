{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Finding Packet v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "source_issue", "commit_sha", "summary", "reproduction", "severity", "within_scope", "affects_acceptance", "evidence"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "finding" },
    "source_issue": { "type": "integer", "minimum": 1 },
    "commit_sha": { "type": "string", "minLength": 7 },
    "summary": { "type": "string", "minLength": 1 },
    "reproduction": { "type": "array", "minItems": 1 },
    "severity": { "enum": ["Low", "Medium", "High"] },
    "within_scope": { "type": "boolean" },
    "affects_acceptance": { "type": "boolean" },
    "evidence": { "type": "array", "minItems": 1 }
  }
}
