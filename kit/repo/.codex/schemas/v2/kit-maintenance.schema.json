{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kit Maintenance Packet v2",
  "type": "object",
  "required": [
    "schema_version",
    "packet_type",
    "fingerprint",
    "repository",
    "target_repository",
    "source_issue",
    "summary",
    "managed_paths",
    "target_adoption",
    "adoption_required"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "kit_maintenance" },
    "fingerprint": { "$ref": "#/$defs/digest" },
    "repository": { "$ref": "#/$defs/repository" },
    "target_repository": { "$ref": "#/$defs/repository" },
    "source_issue": {
      "type": "object",
      "required": ["repository", "number"],
      "properties": {
        "repository": { "$ref": "#/$defs/repository" },
        "number": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "summary": { "type": "string", "minLength": 1 },
    "managed_paths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/path" }
    },
    "target_adoption": {
      "type": "object",
      "required": ["host_paths", "generated_paths"],
      "properties": {
        "host_paths": { "$ref": "#/$defs/path_list" },
        "generated_paths": { "$ref": "#/$defs/path_list" }
      },
      "additionalProperties": false
    },
    "adoption_required": { "const": true }
  },
  "$defs": {
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*(?:^|/)\\.git(?:/|$)).+$"
    },
    "path_list": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/path" }
    }
  },
  "additionalProperties": false
}
