{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worker Packet v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "repository", "plan_item_id", "issue", "branch", "phase", "base_sha_at_launch", "scope", "out_of_scope", "merge_outcome", "primary_signal", "acceptance", "owner_layer", "conflict_keys", "touch_points", "dependencies", "integration_order", "validation", "reviewers", "human_gates"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "worker" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "plan_item_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
    "issue": { "type": "integer", "minimum": 1 },
    "branch": { "type": "string", "pattern": "^agent/[0-9]+-[a-z0-9][a-z0-9-]*$" },
    "phase": { "type": "string", "minLength": 1 },
    "base_sha_at_launch": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "scope": { "$ref": "#/$defs/string_list" },
    "out_of_scope": { "$ref": "#/$defs/string_list" },
    "merge_outcome": { "type": "string", "minLength": 1 },
    "primary_signal": { "type": "string", "minLength": 1 },
    "acceptance": { "type": "array", "minItems": 3, "maxItems": 5, "items": { "type": "string", "minLength": 1 } },
    "owner_layer": { "type": "string", "minLength": 1 },
    "conflict_keys": { "$ref": "#/$defs/conflict_keys" },
    "touch_points": { "$ref": "#/$defs/string_list" },
    "dependencies": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
    "integration_order": { "type": "integer", "minimum": 1 },
    "validation": {
      "type": "object",
      "required": ["targeted", "full", "integration"],
      "properties": {
        "targeted": { "$ref": "#/$defs/string_list" },
        "full": { "$ref": "#/$defs/string_list" },
        "integration": { "$ref": "#/$defs/string_list" }
      },
      "additionalProperties": false
    },
    "reviewers": { "type": "array", "contains": { "const": "admission-reviewer" }, "minContains": 1 },
    "human_gates": { "$ref": "#/$defs/string_list" }
  },
  "$defs": {
    "string_list": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "conflict_keys": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" } }
  },
  "additionalProperties": false
}
