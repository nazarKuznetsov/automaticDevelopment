{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Human Action Required v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "issue", "blocked_state", "reason", "evidence", "decision_required", "safe_options", "resume_condition"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "human_action_required" },
    "issue": { "type": ["integer", "null"] },
    "blocked_state": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "evidence": { "type": "array" },
    "decision_required": { "type": "string", "minLength": 1 },
    "safe_options": { "type": "array", "minItems": 1, "maxItems": 2 },
    "resume_condition": { "type": "string", "minLength": 1 }
  }
}
