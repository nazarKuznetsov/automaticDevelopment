{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orchestrator Start Packet v2",
  "type": "object",
  "required": ["schema_version", "packet_type", "wave_id", "phase_plan_revision", "base_sha", "approved_plan_items", "authorization", "valid_until"],
  "properties": {
    "schema_version": { "const": 2 },
    "packet_type": { "const": "orchestrator_start" },
    "wave_id": { "type": "string", "minLength": 1 },
    "phase_plan_revision": { "type": "string", "minLength": 1 },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "approved_plan_items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["plan_item_id", "conflict_keys"],
        "properties": {
          "plan_item_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
          "conflict_keys": { "$ref": "#/$defs/conflict_keys" }
        },
        "additionalProperties": false
      }
    },
    "authorization": {
      "type": "object",
      "required": ["status", "create_top_level_worker_tasks", "managed_worktrees", "max_worker_launches", "max_concurrent_write_workers", "monitor_and_steer", "archive_after_done", "create_high_risk_review_tasks", "merge_requires_exact_sha_authorization"],
      "properties": {
        "status": { "const": "APPROVED" },
        "create_top_level_worker_tasks": { "const": true },
        "managed_worktrees": { "const": true },
        "max_worker_launches": { "const": 5 },
        "max_concurrent_write_workers": { "const": 2 },
        "monitor_and_steer": { "const": true },
        "archive_after_done": { "const": true },
        "create_high_risk_review_tasks": { "const": true },
        "merge_requires_exact_sha_authorization": { "const": true },
        "approved_by": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "valid_until": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "conflict_keys": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
    }
  },
  "additionalProperties": false
}
